{
  "name": "elsfa-vue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:admin": "pnpm --filter @elsfa/admin dev",
    "dev:docs": "pnpm --filter @elsfa/docs dev",
    "build:admin": "pnpm --filter @elsfa/admin build",
    "build:docs": "pnpm --filter @elsfa/docs build",
    "dev": "pnpm --filter @elsfa/admin dev",
    "build": "pnpm --filter @elsfa/admin build",
    "preview": "pnpm --filter @elsfa/admin preview",
    "postinstall": "nuxt prepare",
    "test:e2e": "playwright test",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint --fix",
    "lint:eslint": "eslint --fix --cache",
    "format": "oxfmt ."
  },
  "devDependencies": {
    "@nuxt/devtools": "^2.4.0",
    "@playwright/test": "^1.58.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.12.0",
    "@vitest/eslint-plugin": "^1.6.10",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.51.0",
    "eslint-plugin-playwright": "^2.9.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^8.0.4",
    "nuxt": "catalog:",
    "oxfmt": "^0.37.0",
    "oxlint": "~1.51.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": ">=22.5.0",
    "pnpm": ">=9.10.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sqlite3"
    ]
  }
}
